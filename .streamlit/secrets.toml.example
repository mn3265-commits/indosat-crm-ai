TWILIO_TOKEN       = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_PHONE_FROM  = "+1xxxxxxxxxx"           # Your Twilio phone number (for voice calls)
ANTHROPIC_API_KEY  = "sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx"
